{
    "name": "crazy-goat/the-consoomer",
    "description": "Symfony Messenger AMQP transport using consume instead of get",
    "type": "library",
    "license": "MIT",
    "keywords": ["symfony", "messenger", "amqp", "rabbitmq", "transport"],
    "authors": [
        {
            "name": "Piotr Hałas",
            "email": "piotr.halas@crazy-goat.com"
        }
    ],
    "autoload":{
        "psr-4": {
            "CrazyGoat\\TheConsoomer\\": "src/"
        }
    },
    "autoload-dev":{
        "psr-4": {
            "CrazyGoat\\TheConsoomer\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "ext-amqp": "*",
        "symfony/messenger": "^6.4 || ^7.4 || ^8.0"
    },
    "require-dev": {
        "symfony/console": "^6.4 || ^7.4 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.4 || ^8.0",
        "friendsofphp/php-cs-fixer": "^3.75",
        "rector/rector": "^2.0",
        "phpunit/phpunit": "^10"
    },
    "scripts": {
        "rector": "vendor/bin/rector process",
        "phpcsfixer": "vendor/bin/php-cs-fixer fix",
        "lint": [
            "@rector",
            "@phpcsfixer"
        ],
        "run-rabbitmq": "docker run --rm -p 15672:15672 -p 5672:5672 --hostname my-rabbit --name some-rabbit rabbitmq:4.1-management-alpine",
        "test": "phpunit",
        "test-unit": "phpunit --testsuite unit",
        "test-e2e": "phpunit --testsuite e2e",
        "test-coverage": "phpunit --coverage-html coverage",
        "rabbitmq-start": "docker compose -f docker-compose.test.yml up -d",
        "rabbitmq-stop": "docker compose -f docker-compose.test.yml down",
        "rabbitmq-wait": "scripts/wait-for-rabbitmq.sh",
        "test-e2e-full": [
            "@rabbitmq-start",
            "@rabbitmq-wait",
            "@test-e2e",
            "@rabbitmq-stop"
        ]
    }
}
